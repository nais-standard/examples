Options -Indexes

# ─── Security Headers ────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ─── CORS for /.well-known/agent.json ────────────────────────────────────────
<Files "agent.json">
    <IfModule mod_headers.c>
        Header always set Access-Control-Allow-Origin "*"
        Header always set Access-Control-Allow-Methods "GET, OPTIONS"
        Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
        Header always set Content-Type "application/json; charset=utf-8"
        Header always set Cache-Control "public, max-age=300"
    </IfModule>
</Files>

# ─── Routing ─────────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Allow .well-known directory
    RewriteRule ^\.well-known/ - [L]

    # OPTIONS pre-flight: pass directly to mcp.php
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^mcp$ mcp.php [L]

    # /mcp → mcp.php
    RewriteRule ^mcp$ mcp.php [L]

    # Deny access to other hidden files
    RewriteRule (^\.|/\.) - [F]
</IfModule>
